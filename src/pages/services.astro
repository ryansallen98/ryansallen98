---
import Button from "@components/ui/Button.astro";
import ListItem from "@components/ui/ListItem.astro";
import SubHeading from "@components/ui/SubHeading.astro";
import Layout from "@layouts/BaseLayout.astro";
import servicesPage from "@data/general/services.yml";

type Cta = {
  text: string;
  href: string;
};

type Service = {
  title: string;
  description: string;
  tags: string[];
  cta: Cta;
};

type Step = {
  title: string;
  text: string;
};

const hero = servicesPage.hero as {
  eyebrow: string;
  title: string;
  intro: string;
  primaryCta: Cta;
  secondaryCta: Cta;
};
const services = servicesPage.services as {
  eyebrow: string;
  title: string;
  items: Service[];
};
const process = servicesPage.process as {
  eyebrow: string;
  title: string;
  steps: Step[];
};
const cta = servicesPage.cta as {
  eyebrow: string;
  title: string;
  text: string;
  primaryCta: Cta;
  secondaryCta: Cta;
};
---

<Layout title={hero.title}>
  <section class="bg-background-dark pt-28 pb-16 text-foreground-dark sm:pt-32 lg:pt-36 lg:pb-24">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="grid gap-8 lg:grid-cols-[1fr_0.75fr] lg:items-end">
        <div class="flex flex-col gap-7">
          <SubHeading text={hero.eyebrow} class="fade-in" />
          <h1 class="reveal-title font-hero max-w-5xl">{hero.title}</h1>
        </div>
        <div class="flex flex-col gap-7">
          <p class="max-w-xl text-lg leading-relaxed text-muted">{hero.intro}</p>
          <div class="flex flex-wrap gap-2">
            <Button as="a" href={hero.primaryCta.href} text={hero.primaryCta.text} variant="primary" iconEnd="lucide:arrow-right" />
            <Button as="a" href={hero.secondaryCta.href} text={hero.secondaryCta.text} variant="outline" iconEnd="lucide:arrow-right" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background-light py-18 text-foreground-light lg:py-28">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="mb-12 grid gap-8 lg:grid-cols-[0.75fr_1.25fr]">
        <div class="flex flex-col gap-6">
          <SubHeading text={services.eyebrow} class="text-foreground-light" />
          <h2 class="reveal-title font-h2 max-w-xl">{services.title}</h2>
        </div>
      </div>
      <div class="grid border-t border-divider-light">
        {
          services.items.map((service: Service, index: number) => (
            <article class="reveal-card grid gap-6 border-b border-divider-light py-8 lg:grid-cols-[120px_1fr_0.38fr] lg:items-start" style={`transition-delay: ${index * 70}ms`}>
              <p class="font-heading text-5xl text-primary">0{index + 1}</p>
              <div class="flex flex-col gap-4">
                <h3 class="font-h3">{service.title}</h3>
                <p class="max-w-3xl leading-relaxed text-secondary-foreground-light">{service.description}</p>
                <ul class="flex flex-wrap gap-x-5 gap-y-2 text-sm uppercase">
                  {service.tags.map((tag: string) => <ListItem>{tag}</ListItem>)}
                </ul>
              </div>
              <Button as="a" href={service.cta.href} text={service.cta.text} variant="dark" iconEnd="lucide:arrow-right" class="w-fit" />
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-background-dark py-18 text-foreground-dark lg:py-28">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="grid gap-12 lg:grid-cols-[0.85fr_1.15fr]">
        <div class="flex flex-col gap-6">
          <SubHeading text={process.eyebrow} />
          <h2 class="reveal-title font-h2 max-w-xl">{process.title}</h2>
        </div>
        <div class="grid gap-4">
          {
            process.steps.map((step: Step, index: number) => (
              <article class="reveal-card grid gap-4 border border-divider-dark bg-secondary-dark p-6 sm:grid-cols-[96px_1fr]" style={`transition-delay: ${index * 80}ms`}>
                <span class="font-heading text-5xl text-primary">0{index + 1}</span>
                <div>
                  <h3 class="font-h4">{step.title}</h3>
                  <p class="mt-3 max-w-2xl leading-relaxed text-muted">{step.text}</p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="bg-primary py-18 text-primary-foreground lg:py-24">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="grid gap-8 lg:grid-cols-[1fr_0.8fr] lg:items-end">
        <div class="flex flex-col gap-5">
          <SubHeading text={cta.eyebrow} class="[&_span:last-child]:border-primary-foreground" />
          <h2 class="font-h2 max-w-3xl">{cta.title}</h2>
        </div>
        <div class="flex flex-col gap-7">
          <p class="max-w-xl text-lg leading-relaxed">{cta.text}</p>
          <div class="flex flex-wrap gap-2">
            <Button as="a" href={cta.primaryCta.href} text={cta.primaryCta.text} variant="dark" iconEnd="lucide:arrow-right" />
            <Button as="a" href={cta.secondaryCta.href} text={cta.secondaryCta.text} variant="outline" class="border-primary-foreground text-primary-foreground hover:bg-primary-foreground hover:text-primary" iconEnd="lucide:arrow-right" />
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
