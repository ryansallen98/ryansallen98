---
import Button from "@components/ui/Button.astro";
import SubHeading from "@components/ui/SubHeading.astro";
import Layout from "@layouts/BaseLayout.astro";
import pricing from "@data/general/pricing.yml";
import { Icon } from "astro-icon/components";

type Cta = {
  text: string;
  href: string;
};

type Plan = {
  title: string;
  price: string;
  description: string;
  features: string[];
  cta: Cta;
};

const hero = pricing.hero as {
  eyebrow: string;
  title: string;
  intro: string;
  primaryCta: Cta;
  secondaryCta: Cta;
};
const plans = pricing.plans as {
  eyebrow: string;
  title: string;
  items: Plan[];
};
const support = pricing.support as {
  eyebrow: string;
  title: string;
  text: string;
};
const cta = pricing.cta as {
  eyebrow: string;
  title: string;
  text: string;
  primaryCta: Cta;
  secondaryCta: Cta;
};
---

<Layout title={hero.title}>
  <section class="bg-background-dark pt-28 pb-16 text-foreground-dark sm:pt-32 lg:pt-36 lg:pb-24">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="grid gap-8 lg:grid-cols-[1fr_0.75fr] lg:items-end">
        <div class="flex flex-col gap-7">
          <SubHeading text={hero.eyebrow} />
          <h1 class="reveal-title font-hero max-w-5xl">{hero.title}</h1>
        </div>
        <div class="flex flex-col gap-7">
          <p class="max-w-xl text-lg leading-relaxed text-muted">{hero.intro}</p>
          <div class="flex flex-wrap gap-2">
            <Button as="a" href={hero.primaryCta.href} text={hero.primaryCta.text} variant="primary" iconEnd="lucide:arrow-right" />
            <Button as="a" href={hero.secondaryCta.href} text={hero.secondaryCta.text} variant="outline" iconEnd="lucide:arrow-right" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background-light py-18 text-foreground-light lg:py-28">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="mb-12 flex max-w-3xl flex-col gap-6">
        <SubHeading text={plans.eyebrow} class="text-foreground-light" />
        <h2 class="reveal-title font-h2">{plans.title}</h2>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {
          plans.items.map((plan: Plan, index: number) => (
            <article class="reveal-card flex min-h-[430px] flex-col justify-between border border-divider-light bg-secondary-light p-6 lg:p-8" style={`transition-delay: ${index * 80}ms`}>
              <div class="flex flex-col gap-5">
                <p class="font-h4 text-primary">{plan.price}</p>
                <div>
                  <h3 class="font-h3">{plan.title}</h3>
                  <p class="mt-4 max-w-2xl leading-relaxed text-secondary-foreground-light">{plan.description}</p>
                </div>
                <ul class="grid gap-3 text-sm uppercase">
                  {plan.features.map((feature: string) => (
                    <li class="flex items-start gap-3">
                      <Icon name="lucide:check" class="mt-0.5 size-4 text-primary" aria-hidden="true" />
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <Button as="a" href={plan.cta.href} text={plan.cta.text} variant="dark" iconEnd="lucide:arrow-right" class="mt-8 w-fit" />
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-background-dark py-18 text-foreground-dark lg:py-24">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="grid gap-8 border-y border-divider-dark py-10 lg:grid-cols-[0.75fr_1.25fr] lg:items-center">
        <div class="flex flex-col gap-5">
          <SubHeading text={support.eyebrow} />
          <h2 class="font-h2 max-w-xl">{support.title}</h2>
        </div>
        <p class="max-w-3xl text-lg leading-relaxed text-muted">{support.text}</p>
      </div>
    </div>
  </section>

  <section class="bg-primary py-18 text-primary-foreground lg:py-24">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="grid gap-8 lg:grid-cols-[1fr_0.8fr] lg:items-end">
        <div class="flex flex-col gap-5">
          <SubHeading text={cta.eyebrow} class="[&_span:last-child]:border-primary-foreground" />
          <h2 class="font-h2 max-w-3xl">{cta.title}</h2>
        </div>
        <div class="flex flex-col gap-7">
          <p class="max-w-xl text-lg leading-relaxed">{cta.text}</p>
          <div class="flex flex-wrap gap-2">
            <Button as="a" href={cta.primaryCta.href} text={cta.primaryCta.text} variant="dark" iconEnd="lucide:arrow-right" />
            <Button as="a" href={cta.secondaryCta.href} text={cta.secondaryCta.text} variant="outline" class="border-primary-foreground text-primary-foreground hover:bg-primary-foreground hover:text-primary" iconEnd="lucide:arrow-right" />
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
