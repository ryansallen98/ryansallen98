---
import Button from "@components/ui/Button.astro";
import ListItem from "@components/ui/ListItem.astro";
import SubHeading from "@components/ui/SubHeading.astro";
import Layout from "@layouts/BaseLayout.astro";
import sharedFaqs from "@data/general/faqs.yml";
import home from "@data/general/home.yml";
import { Icon } from "astro-icon/components";

type Cta = { text: string; href: string };
type HeroImage = { src: string; alt: string; note?: string };
type HeroHighlight = { label: string; text: string };
type Stat = { value: string; label: string };
type ServiceCard = {
  title: string;
  description: string;
  items: string[];
  href: string;
};
type ProofItem = {
  company: string;
  role: string;
  timeframe: string;
  summary: string;
  tags: string[];
};
type EngagementCard = {
  title: string;
  price: string;
  description: string;
  items: string[];
  cta: Cta;
  recommended?: boolean;
};
type ProcessStep = { title: string; text: string };
type FaqItem = { question: string; answer: string };
type FaqGroup = {
  key: string;
  label: string;
  eyebrow: string;
  title: string;
  items: FaqItem[];
};
type WorkItem = {
  number: string;
  project: string;
  title: string;
  summary: string;
  tags: string[];
  image: HeroImage;
  cta: Cta;
};

const hero = home.hero as {
  eyebrow: string;
  title: string;
  titleAccent?: string;
  intro: string;
  metadata: string[];
  primaryCta: Cta;
  secondaryCta: Cta;
  availability: string;
  status: { label: string; location?: string };
  image: HeroImage;
  highlights: HeroHighlight[];
};
const seo = home.seo;

const marquee = (home.marquee as string[]) ?? [];
const stats = home.stats as Stat[];
const work = home.work as {
  eyebrow: string;
  title: string;
  intro: string;
  meta?: string;
  items: WorkItem[];
};
const services = home.services as {
  eyebrow: string;
  title: string;
  intro: string;
  cards: ServiceCard[];
};
const proof = home.proof as {
  eyebrow: string;
  title: string;
  intro: string;
  items: ProofItem[];
};
const engagements = home.engagements as {
  eyebrow: string;
  title: string;
  intro: string;
  cards: EngagementCard[];
};
const process = home.process as {
  eyebrow: string;
  title: string;
  steps: ProcessStep[];
};
const faq = (sharedFaqs.groups as FaqGroup[]).find(
  (group) => group.key === "homepage"
) as FaqGroup;
const cta = home.cta as {
  eyebrow: string;
  title: string;
  text: string;
  primaryCta: Cta;
  secondaryCta: Cta;
};
---

<Layout title={hero.title} seo={seo} preloadImage={hero.image.src}>
  <!-- HERO -->
  <section
    class="relative overflow-hidden bg-background-dark pt-28 pb-16 text-foreground-dark sm:pt-32 lg:pt-36 lg:pb-24"
  >
    <div class="container relative mx-auto max-w-7xl px-5">
      <div class="grid gap-12 lg:grid-cols-[minmax(280px,0.55fr)_minmax(0,1.18fr)] lg:items-stretch lg:gap-16">
        <a
          href="/about"
          aria-label="About Ryan Allen"
          class="reveal-image group relative order-2 block overflow-hidden border border-divider-dark bg-secondary-dark fade-in delay-400 lg:order-1 lg:h-full"
        >
          <img
            src={hero.image.src}
            alt={hero.image.alt}
            class="aspect-4/5 h-full w-full object-cover object-center grayscale transition duration-700 group-hover:scale-[1.04] group-hover:grayscale-0 lg:aspect-auto"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            width="960"
            height="1280"
          />
          {
            hero.status.location && (
              <div class="absolute left-4 top-4 flex items-center gap-2 border border-divider-dark bg-background-dark/70 px-2.5 py-1 backdrop-blur">
                <span class="status-dot inline-flex size-1.5 rounded-full bg-primary" />
                <span class="text-[10px] uppercase tracking-[0.22em] text-foreground-dark">
                  {hero.status.location}
                </span>
              </div>
            )
          }
          <span
            class="absolute inset-x-0 bottom-0 flex items-center justify-between border-t border-divider-dark bg-background-dark/85 p-4 text-[11px] uppercase tracking-[0.2em] text-muted backdrop-blur transition-colors duration-300 group-hover:text-foreground-dark"
          >
            <span>About Ryan</span>
            <Icon
              name="lucide:arrow-up-right"
              class="size-5 text-primary transition-transform duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
              aria-hidden="true"
            />
          </span>
        </a>

        <div class="order-1 flex flex-col gap-8 lg:order-2 lg:justify-center">
          <h1 class="reveal-title font-heading uppercase tracking-normal leading-none text-[clamp(2.25rem,5.2vw,4.5rem)] max-w-4xl">
            <span class="block font-heading">{hero.title}</span>
            {
              hero.titleAccent && (
                <span class="block font-heading text-primary">
                  {hero.titleAccent}
                </span>
              )
            }
          </h1>

          <p
            class="max-w-2xl text-base leading-relaxed text-muted fade-in delay-200 sm:text-lg lg:text-xl"
          >
            {hero.intro}
          </p>

          <div class="flex flex-wrap gap-3 fade-in delay-400">
            <Button
              as="a"
              href={hero.primaryCta.href}
              text={hero.primaryCta.text}
              variant="primary"
              iconEnd="lucide:arrow-right"
            />
            <Button
              as="a"
              href={hero.secondaryCta.href}
              text={hero.secondaryCta.text}
              variant="outline"
              iconEnd="lucide:arrow-right"
            />
          </div>

          <div
            class="mt-2 flex flex-col gap-5 border-l-2 border-primary pl-5 fade-in delay-600"
          >
            <p class="max-w-xl text-sm leading-relaxed text-muted">
              {hero.availability}
            </p>
            <ul
              class="flex flex-wrap gap-x-5 gap-y-2 text-xs uppercase tracking-[0.14em] text-foreground-dark"
            >
              {hero.metadata.map((item: string) => <ListItem>{item}</ListItem>)}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MARQUEE TAPE -->
  {
    marquee.length > 0 && (
      <section class="border-y border-divider-dark bg-background-dark py-8 text-foreground-dark">
        <div class="marquee" aria-hidden="true">
          <div class="marquee__track">
            {[0, 1].map(() => (
              <div class="marquee__group">
                {marquee.map((item: string) => (
                  <div class="flex items-center gap-6">
                    <span class="font-heading text-3xl uppercase leading-none sm:text-4xl lg:text-5xl">
                      {item}
                    </span>
                    <span class="size-2 shrink-0 bg-primary" />
                  </div>
                ))}
              </div>
            ))}
          </div>
        </div>
        <p class="sr-only">
          Focus areas: {marquee.join(", ")}
        </p>
      </section>
    )
  }

  <!-- ABOUT + STATS -->
  <section class="bg-background-light py-16 text-foreground-light lg:py-24">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:items-end lg:gap-16">
        <div class="flex flex-col gap-6">
          <SubHeading text="The story so far" class="fade-in text-foreground-light" />
          <h2 class="reveal-title font-h2 max-w-xl">
            Startup operator who ships the system, not just the screen.
          </h2>
          <p
            class="max-w-xl text-base leading-relaxed text-secondary-foreground-light fade-in delay-200 lg:text-lg"
          >
            From CPA funnels to startup dashboards and AI-assisted product work, the through-line is the same: practical interfaces, calm code, and tools real teams use without a manual.
          </p>
        </div>

        <div class="grid border-y border-divider-light sm:grid-cols-2 lg:grid-cols-4">
          {
            stats.map((stat: Stat, index: number) => (
              <div
                class="reveal-card border-divider-light py-6 sm:px-5 sm:odd:border-r lg:border-r lg:last:border-r-0"
                style={`transition-delay: ${index * 70}ms`}
              >
                <p class="font-heading text-4xl uppercase leading-none text-foreground-light whitespace-nowrap sm:text-5xl">
                  {
                    stat.value.includes("/") ? (
                      <>
                        <span class="font-heading">
                          {stat.value.split("/")[0]}
                        </span>
                        <span class="font-heading text-xl text-secondary-foreground-light sm:text-2xl">
                          /{stat.value.split("/").slice(1).join("/")}
                        </span>
                      </>
                    ) : (
                      stat.value
                    )
                  }
                </p>
                <p class="mt-3 max-w-44 text-xs uppercase tracking-[0.16em] leading-relaxed text-secondary-foreground-light">
                  {stat.label}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- SELECTED WORKS -->
  <section class="bg-background-dark py-18 text-foreground-dark lg:py-28">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="mb-12 grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
        <div class="flex flex-col gap-6">
          <SubHeading text={work.eyebrow} class="fade-in" />
          <h2 class="reveal-title font-h2 max-w-2xl">{work.title}</h2>
        </div>
        <div class="flex flex-col gap-4">
          <p
            class="max-w-2xl text-lg leading-relaxed text-muted fade-in delay-200"
          >
            {work.intro}
          </p>
          {
            work.meta && (
              <p class="max-w-2xl text-[11px] uppercase tracking-[0.2em] text-primary fade-in delay-400">
                {work.meta}
              </p>
            )
          }
        </div>
      </div>

      <div class="border-t border-divider-dark">
        {
          work.items.map((item: WorkItem, index: number) => (
            <a
              href={item.cta.href}
              class="reveal-card group grid gap-8 border-b border-divider-dark py-8 transition duration-300 hover:border-primary lg:grid-cols-[140px_minmax(0,1fr)_minmax(280px,0.55fr)] lg:items-center lg:gap-10 lg:py-12"
              style={`transition-delay: ${index * 80}ms`}
              aria-label={`${item.project}: ${item.title}`}
            >
              <div class="flex items-center gap-4 lg:flex-col lg:items-start lg:gap-5">
                <span class="font-heading text-5xl leading-none text-primary lg:text-6xl">
                  {item.number}
                </span>
                <span class="hidden h-px w-12 bg-divider-dark lg:block" />
                <span class="text-[11px] uppercase tracking-[0.18em] text-muted">
                  {item.project}
                </span>
              </div>

              <div class="flex flex-col gap-4">
                <h3 class="font-h3 max-w-xl transition-colors duration-300 group-hover:text-primary">
                  {item.title}
                </h3>
                <p class="max-w-2xl leading-relaxed text-muted">
                  {item.summary}
                </p>
                <ul class="mt-2 flex flex-wrap gap-2">
                  {item.tags.map((tag: string) => (
                    <li class="border border-divider-dark px-3 py-1 text-[11px] uppercase tracking-[0.16em] text-foreground-dark">
                      {tag}
                    </li>
                  ))}
                </ul>
              </div>

              <div class="relative aspect-16/10 overflow-hidden border border-divider-dark bg-secondary-dark">
                <img
                  src={item.image.src}
                  alt={item.image.alt}
                  class="h-full w-full object-cover transition duration-700 group-hover:scale-[1.06]"
                  loading="lazy"
                  decoding="async"
                  width="960"
                  height="600"
                />
                <span class="absolute inset-0 bg-background-dark/0 transition duration-300 group-hover:bg-background-dark/45" />
                <span class="absolute inset-0 flex items-center justify-center opacity-0 transition duration-300 group-hover:opacity-100">
                  <span class="flex size-16 items-center justify-center rounded-full border border-primary bg-primary text-primary-foreground shadow-lg">
                    <Icon
                      name="lucide:arrow-up-right"
                      class="size-7"
                      aria-hidden="true"
                    />
                  </span>
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="bg-background-light py-18 text-foreground-light lg:py-28">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="grid gap-10 lg:grid-cols-[0.75fr_1.25fr] lg:gap-16">
        <div class="flex flex-col gap-6">
          <SubHeading
            text={services.eyebrow}
            class="fade-in text-foreground-light"
          />
          <h2 class="reveal-title font-h2 max-w-xl">{services.title}</h2>
          <p
            class="max-w-xl text-base leading-relaxed text-secondary-foreground-light fade-in delay-200 lg:text-lg"
          >
            {services.intro}
          </p>
        </div>

        <div class="grid border-t border-divider-light">
          {
            services.cards.map((card: ServiceCard, index: number) => (
              <a
                href={card.href}
                class="reveal-card group grid gap-6 border-b border-divider-light py-7 transition duration-300 hover:border-primary md:grid-cols-[100px_1fr_auto] md:items-start md:py-9"
                style={`transition-delay: ${index * 80}ms`}
              >
                <span class="font-heading text-5xl leading-none text-primary lg:text-6xl">
                  0{index + 1}
                </span>
                <div class="flex flex-col gap-4">
                  <h3 class="font-h3 transition-colors duration-300 group-hover:text-primary">
                    {card.title}
                  </h3>
                  <p class="max-w-2xl leading-relaxed text-secondary-foreground-light">
                    {card.description}
                  </p>
                  <ul class="flex flex-wrap gap-x-5 gap-y-2 text-xs uppercase tracking-[0.14em]">
                    {card.items.map((item: string) => (
                      <ListItem>{item}</ListItem>
                    ))}
                  </ul>
                </div>
                <span class="flex size-12 items-center justify-center border border-divider-light transition duration-300 group-hover:border-primary group-hover:bg-primary group-hover:text-primary-foreground">
                  <Icon
                    name="lucide:arrow-up-right"
                    class="size-5 transition duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                    aria-hidden="true"
                  />
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- EXPERIENCE TIMELINE -->
  <section class="bg-background-dark py-18 text-foreground-dark lg:py-28">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="mb-12 grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
        <div class="flex flex-col gap-6">
          <SubHeading text={proof.eyebrow} class="fade-in" />
          <h2 class="reveal-title font-h2 max-w-2xl">{proof.title}</h2>
        </div>
        <p
          class="max-w-2xl text-lg leading-relaxed text-muted fade-in delay-200"
        >
          {proof.intro}
        </p>
      </div>

      <div class="border-t border-divider-dark">
        {
          proof.items.map((item: ProofItem, index: number) => (
            <article
              class="reveal-card grid gap-6 border-b border-divider-dark py-8 lg:grid-cols-[200px_minmax(0,1fr)_minmax(0,1.2fr)] lg:items-start lg:gap-10 lg:py-10"
              style={`transition-delay: ${index * 70}ms`}
            >
              <p class="font-heading text-2xl uppercase leading-none text-primary lg:text-3xl">
                {item.timeframe}
              </p>
              <div class="flex flex-col gap-1">
                <p class="text-[11px] uppercase tracking-[0.18em] text-muted">
                  {item.role}
                </p>
                <h3 class="font-h3">{item.company}</h3>
              </div>
              <div class="flex flex-col gap-4">
                <p class="leading-relaxed text-muted">{item.summary}</p>
                <ul class="flex flex-wrap gap-2">
                  {item.tags.map((tag: string) => (
                    <li class="border border-divider-dark px-3 py-1 text-[11px] uppercase tracking-[0.16em] text-foreground-dark">
                      {tag}
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ENGAGEMENTS -->
  <section class="bg-background-light py-18 text-foreground-light lg:py-28">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="mb-12 flex flex-col gap-6">
        <SubHeading
          text={engagements.eyebrow}
          class="fade-in text-foreground-light"
        />
        <h2 class="reveal-title font-h2 max-w-3xl">{engagements.title}</h2>
        <p
          class="max-w-2xl text-lg leading-relaxed text-secondary-foreground-light fade-in delay-200"
        >
          {engagements.intro}
        </p>
      </div>

      <div class="grid gap-4 lg:grid-cols-3 lg:gap-5">
        {
          engagements.cards.map((card: EngagementCard, index: number) => {
            const isRecommended = !!card.recommended;
            const cardClass = isRecommended
              ? "border-primary bg-background-light shadow-[0_30px_60px_-30px_rgba(0,0,0,0.18)] lg:-translate-y-2"
              : "border-divider-light bg-secondary-light";
            return (
              <article
                class={`reveal-card relative flex min-h-[460px] flex-col justify-between gap-8 border ${cardClass} p-7 transition duration-300 lg:p-9`}
                style={`transition-delay: ${index * 90}ms`}
              >
                <div class="flex flex-col gap-5">
                  <div class="flex items-center justify-between gap-3">
                    <span class="text-[11px] uppercase tracking-[0.2em] text-secondary-foreground-light">
                      0{index + 1}
                    </span>
                    {isRecommended && (
                      <span class="inline-flex items-center gap-2 bg-primary px-3 py-1 text-[11px] uppercase tracking-[0.2em] text-primary-foreground">
                        <span class="size-1.5 rounded-full bg-primary-foreground" />
                        Recommended
                      </span>
                    )}
                  </div>
                  <h3 class="font-h3">{card.title}</h3>
                  <p class="font-heading text-3xl uppercase leading-none text-primary lg:text-4xl">
                    {card.price}
                  </p>
                  <p class="leading-relaxed text-secondary-foreground-light">
                    {card.description}
                  </p>
                  <ul class="mt-2 grid gap-3 text-sm">
                    {card.items.map((item: string) => (
                      <li class="flex items-start gap-3">
                        <Icon
                          name="lucide:check"
                          class="mt-0.5 size-4 shrink-0 text-primary"
                          aria-hidden="true"
                        />
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
                <Button
                  as="a"
                  href={card.cta.href}
                  text={card.cta.text}
                  variant={isRecommended ? "primary" : "dark"}
                  iconEnd="lucide:arrow-right"
                  class="w-fit"
                />
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="bg-background-dark py-18 text-foreground-dark lg:py-28">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="mb-12 grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
        <div class="flex flex-col gap-6">
          <SubHeading text={process.eyebrow} class="fade-in" />
          <h2 class="reveal-title font-h2 max-w-2xl">{process.title}</h2>
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-3 md:gap-0 md:border md:border-divider-dark">
        {
          process.steps.map((step: ProcessStep, index: number) => {
            const isLast = index === process.steps.length - 1;
            return (
              <article
                class={`reveal-card relative flex flex-col gap-6 border border-divider-dark bg-secondary-dark p-7 md:border-0 ${
                  !isLast ? "md:border-r md:border-divider-dark" : ""
                } lg:p-9`}
                style={`transition-delay: ${index * 90}ms`}
              >
                <div class="flex items-center justify-between">
                  <span class="font-heading text-5xl leading-none text-primary lg:text-6xl">
                    0{index + 1}
                  </span>
                  {!isLast && (
                    <Icon
                      name="lucide:arrow-right"
                      class="hidden size-6 text-divider-dark md:inline-block"
                      aria-hidden="true"
                    />
                  )}
                </div>
                <h3 class="font-h4">{step.title}</h3>
                <p class="max-w-md leading-relaxed text-muted">{step.text}</p>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-secondary-light py-18 text-foreground-light lg:py-28">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="grid gap-12 lg:grid-cols-[0.8fr_1.2fr]">
        <div class="flex flex-col gap-6">
          <SubHeading
            text={faq.eyebrow}
            class="fade-in text-foreground-light"
          />
          <h2 class="reveal-title font-h2 max-w-xl">{faq.title}</h2>
        </div>

        <div class="grid gap-3">
          {
            faq.items.map((item: FaqItem, index: number) => (
              <details
                class="reveal-card group border border-divider-light bg-background-light p-6 open:border-primary"
                style={`transition-delay: ${index * 55}ms`}
              >
                <summary class="flex cursor-pointer list-none items-start justify-between gap-6">
                  <span class="font-h5">{item.question}</span>
                  <Icon
                    name="lucide:plus"
                    class="mt-1 size-5 shrink-0 text-primary transition duration-300 group-open:rotate-45"
                    aria-hidden="true"
                  />
                </summary>
                <p class="mt-5 max-w-3xl leading-relaxed text-secondary-foreground-light">
                  {item.answer}
                </p>
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- CLOSING CTA -->
  <section
    class="relative overflow-hidden bg-primary py-20 text-primary-foreground lg:py-32"
  >
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 grid grid-cols-6 opacity-[0.07] sm:grid-cols-12"
    >
      {Array.from({ length: 12 }).map(() => (
        <span class="border-r border-primary-foreground last:border-r-0"></span>
      ))}
    </div>

    <div class="container relative mx-auto max-w-7xl px-5">
      <div class="grid gap-12 lg:grid-cols-[1.15fr_0.85fr] lg:items-end lg:gap-16">
        <div class="flex flex-col gap-8">
          <SubHeading
            text={cta.eyebrow}
            class="[&_span:last-child]:border-primary-foreground"
          />
          <h2 class="reveal-title font-h2 max-w-3xl">{cta.title}</h2>
        </div>
        <div class="flex flex-col gap-7">
          <p class="max-w-xl text-lg leading-relaxed sm:text-xl">{cta.text}</p>
          <div class="flex flex-wrap gap-3">
            <Button
              as="a"
              href={cta.primaryCta.href}
              text={cta.primaryCta.text}
              variant="dark"
              iconEnd="lucide:arrow-right"
            />
            <Button
              as="a"
              href={cta.secondaryCta.href}
              text={cta.secondaryCta.text}
              variant="outline"
              class="border-primary-foreground text-primary-foreground hover:bg-primary-foreground hover:text-primary"
              iconEnd="lucide:file-text"
            />
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
