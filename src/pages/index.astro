---
import Button from "@components/ui/Button.astro";
import ListItem from "@components/ui/ListItem.astro";
import SubHeading from "@components/ui/SubHeading.astro";
import Layout from "@layouts/BaseLayout.astro";
import sharedFaqs from "@data/general/faqs.yml";
import home from "@data/general/home.yml";
import { Icon } from "astro-icon/components";

type Cta = {
  text: string;
  href: string;
};

type HeroImage = {
  src: string;
  alt: string;
  note?: string;
};

type HeroHighlight = {
  label: string;
  text: string;
};

type Stat = {
  value: string;
  label: string;
};

type ServiceCard = {
  title: string;
  description: string;
  items: string[];
  href: string;
};

type ProofItem = {
  company: string;
  role: string;
  timeframe: string;
  summary: string;
  tags: string[];
};

type EngagementCard = {
  title: string;
  price: string;
  description: string;
  items: string[];
  cta: Cta;
};

type ProcessStep = {
  title: string;
  text: string;
};

type FaqItem = {
  question: string;
  answer: string;
};

type FaqGroup = {
  key: string;
  label: string;
  eyebrow: string;
  title: string;
  items: FaqItem[];
};

const hero = home.hero as {
  eyebrow: string;
  title: string;
  intro: string;
  metadata: string[];
  primaryCta: Cta;
  secondaryCta: Cta;
  availability: string;
  image: HeroImage;
  highlights: HeroHighlight[];
};

const stats = home.stats as Stat[];
const services = home.services as {
  eyebrow: string;
  title: string;
  intro: string;
  cards: ServiceCard[];
};
const proof = home.proof as {
  eyebrow: string;
  title: string;
  intro: string;
  items: ProofItem[];
};
const engagements = home.engagements as {
  eyebrow: string;
  title: string;
  intro: string;
  cards: EngagementCard[];
};
const process = home.process as {
  eyebrow: string;
  title: string;
  steps: ProcessStep[];
};
const faq = (sharedFaqs.groups as FaqGroup[]).find((group) => group.key === "homepage") as FaqGroup;
const cta = home.cta as {
  eyebrow: string;
  title: string;
  text: string;
  primaryCta: Cta;
  secondaryCta: Cta;
};
---

<Layout title={hero.title}>
  <section class="bg-background-dark pt-28 pb-12 text-foreground-dark sm:pt-32 lg:pt-32 lg:pb-14">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1.05fr)_minmax(280px,0.58fr)] lg:items-end">
        <div class="flex flex-col gap-6">
          <SubHeading text={hero.eyebrow} class="fade-in" />

          <div class="flex flex-col gap-6">
            <h1 class="reveal-title font-hero max-w-4xl">
              {hero.title}
            </h1>
            <p class="max-w-2xl text-base leading-relaxed text-muted fade-in delay-400 sm:text-lg">
              {hero.intro}
            </p>
          </div>

          <div class="flex flex-col gap-5 fade-in delay-600">
            <div class="flex flex-wrap gap-2">
              <Button
                as="a"
                href={hero.primaryCta.href}
                text={hero.primaryCta.text}
                variant="primary"
                iconEnd="lucide:arrow-right"
              />
              <Button
                as="a"
                href={hero.secondaryCta.href}
                text={hero.secondaryCta.text}
                variant="outline"
                iconEnd="lucide:arrow-right"
              />
            </div>

            <div class="grid gap-4 border-l border-primary pl-5 md:grid-cols-[0.85fr_1.15fr]">
              <p class="max-w-sm text-sm leading-relaxed text-muted">{hero.availability}</p>
              <ul class="flex flex-wrap gap-x-5 gap-y-2 text-sm uppercase text-foreground-dark">
                {hero.metadata.map((item: string) => <ListItem>{item}</ListItem>)}
              </ul>
            </div>
          </div>
        </div>

        <aside class="hidden fade-in delay-400 md:block">
          <div class="grid gap-4 md:grid-cols-[0.85fr_1.15fr] lg:grid-cols-1">
            <figure class="reveal-image relative overflow-hidden border border-divider-dark bg-secondary-dark">
              <img
                src={hero.image.src}
                alt={hero.image.alt}
                class="aspect-[4/5] h-full w-full object-cover object-center grayscale transition duration-700 hover:scale-105 hover:grayscale-0 lg:aspect-[4/4.5]"
                loading="eager"
              />
              <figcaption class="absolute inset-x-0 bottom-0 flex items-center justify-between border-t border-divider-dark bg-background-dark/88 p-4 text-xs uppercase text-muted backdrop-blur">
                <span>R Allen Dev</span>
                <Icon name="lucide:arrow-up-right" class="size-5 text-primary" aria-hidden="true" />
              </figcaption>
            </figure>

            <div class="grid border border-divider-dark">
              {
                hero.highlights.map((item: HeroHighlight, index: number) => (
                  <div class="reveal-card border-b border-divider-dark p-5 last:border-b-0" style={`transition-delay: ${index * 90 + 160}ms`}>
                    <p class="text-xs uppercase text-primary">{item.label}</p>
                    <p class="mt-2 text-sm leading-relaxed text-muted">{item.text}</p>
                  </div>
                ))
              }
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="bg-background-dark pb-14 text-foreground-dark lg:pb-18">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="grid border-y border-divider-dark sm:grid-cols-2 lg:grid-cols-4">
        {
          stats.map((stat: Stat, index: number) => (
            <div class="reveal-card border-divider-dark py-6 sm:px-6 sm:odd:border-r lg:border-r lg:last:border-r-0" style={`transition-delay: ${index * 70}ms`}>
              <p class="font-heading text-5xl uppercase leading-none text-primary sm:text-6xl">
                {stat.value}
              </p>
              <p class="mt-3 max-w-52 text-sm uppercase leading-relaxed text-muted">
                {stat.label}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-background-light py-18 text-foreground-light lg:py-28">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="grid gap-10 lg:grid-cols-[0.75fr_1.25fr] lg:gap-16">
        <div class="flex flex-col gap-6">
          <SubHeading text={services.eyebrow} class="fade-in text-foreground-light" />
          <h2 class="reveal-title font-h2 max-w-xl">{services.title}</h2>
          <p class="max-w-xl text-lg leading-relaxed text-secondary-foreground-light fade-in delay-400">
            {services.intro}
          </p>
        </div>

        <div class="grid border-t border-divider-light">
          {
            services.cards.map((card: ServiceCard, index: number) => (
              <a
                href={card.href}
                class="reveal-card group grid gap-6 border-b border-divider-light py-7 transition duration-300 hover:border-primary md:grid-cols-[88px_1fr_auto] md:items-start md:py-8"
                style={`transition-delay: ${index * 80}ms`}
              >
                <span class="font-heading text-5xl leading-none text-primary">
                  0{index + 1}
                </span>
                <div class="flex flex-col gap-4">
                  <h3 class="font-h3">{card.title}</h3>
                  <p class="max-w-2xl leading-relaxed text-secondary-foreground-light">
                    {card.description}
                  </p>
                  <ul class="flex flex-wrap gap-x-5 gap-y-2 text-sm uppercase">
                    {card.items.map((item: string) => <ListItem>{item}</ListItem>)}
                  </ul>
                </div>
                <span class="flex size-12 items-center justify-center border border-divider-light transition duration-300 group-hover:border-primary group-hover:bg-primary group-hover:text-primary-foreground">
                  <Icon
                    name="lucide:arrow-up-right"
                    class="size-5 transition duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                    aria-hidden="true"
                  />
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background-dark py-18 text-foreground-dark lg:py-28">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="mb-12 grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
        <div class="flex flex-col gap-6">
          <SubHeading text={proof.eyebrow} class="fade-in" />
          <h2 class="reveal-title font-h2 max-w-2xl">{proof.title}</h2>
        </div>
        <p class="max-w-2xl text-lg leading-relaxed text-muted fade-in delay-400">
          {proof.intro}
        </p>
      </div>

      <div class="grid gap-4 lg:grid-cols-3">
        {
          proof.items.map((item: ProofItem, index: number) => (
            <article class="reveal-card group flex min-h-[300px] flex-col justify-between border border-divider-dark bg-secondary-dark p-6 transition duration-300 hover:-translate-y-1 hover:border-primary lg:p-8" style={`transition-delay: ${index * 90}ms`}>
              <div class="flex items-start justify-between gap-6">
                <span class="font-heading text-5xl leading-none text-primary">0{index + 1}</span>
                <span class="text-right text-xs uppercase leading-relaxed text-muted">
                  {item.timeframe}
                </span>
              </div>
              <div class="flex flex-col gap-5">
                <div>
                  <p class="text-sm uppercase text-muted">{item.role}</p>
                  <h3 class="font-h3 mt-1">{item.company}</h3>
                </div>
                <p class="leading-relaxed text-muted">{item.summary}</p>
                <ul class="flex flex-wrap gap-2">
                  {item.tags.map((tag: string) => (
                    <li class="border border-divider-dark px-3 py-1 text-xs uppercase text-foreground-dark">
                      {tag}
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-background-light py-18 text-foreground-light lg:py-28">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="mb-12 grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
        <div class="flex flex-col gap-6">
          <SubHeading text={engagements.eyebrow} class="fade-in text-foreground-light" />
          <h2 class="reveal-title font-h2 max-w-3xl">{engagements.title}</h2>
        </div>
        <p class="max-w-2xl text-lg leading-relaxed text-secondary-foreground-light fade-in delay-400">
          {engagements.intro}
        </p>
      </div>

      <div class="grid gap-4 lg:grid-cols-3">
        {
          engagements.cards.map((card: EngagementCard, index: number) => (
            <article class="reveal-card flex min-h-[400px] flex-col justify-between border border-divider-light bg-secondary-light p-6 lg:p-8" style={`transition-delay: ${index * 90}ms`}>
              <div class="flex flex-col gap-5">
                <p class="font-h4 text-primary">{card.price}</p>
                <div>
                  <h3 class="font-h3">{card.title}</h3>
                  <p class="mt-4 leading-relaxed text-secondary-foreground-light">
                    {card.description}
                  </p>
                </div>
                <ul class="grid gap-3 text-sm uppercase text-foreground-light">
                  {card.items.map((item: string) => (
                    <li class="flex items-start gap-3">
                      <Icon name="lucide:check" class="mt-0.5 size-4 text-primary" aria-hidden="true" />
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <Button
                as="a"
                href={card.cta.href}
                text={card.cta.text}
                variant="dark"
                iconEnd="lucide:arrow-right"
                class="mt-8 w-fit"
              />
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-background-dark py-18 text-foreground-dark lg:py-28">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="grid gap-12 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
        <div class="flex flex-col gap-6">
          <SubHeading text={process.eyebrow} class="fade-in" />
          <h2 class="reveal-title font-h2 max-w-xl">{process.title}</h2>
        </div>

        <div class="grid gap-4">
          {
            process.steps.map((step: ProcessStep, index: number) => (
              <article class="reveal-card grid gap-5 border border-divider-dark bg-secondary-dark p-6 sm:grid-cols-[120px_1fr] sm:p-8" style={`transition-delay: ${index * 90}ms`}>
                <span class="font-heading text-5xl leading-none text-primary">
                  0{index + 1}
                </span>
                <div class="flex flex-col gap-3">
                  <h3 class="font-h4">{step.title}</h3>
                  <p class="max-w-2xl leading-relaxed text-muted">
                    {step.text}
                  </p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="bg-secondary-light py-18 text-foreground-light lg:py-28">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="grid gap-12 lg:grid-cols-[0.8fr_1.2fr]">
        <div class="flex flex-col gap-6">
          <SubHeading text={faq.eyebrow} class="fade-in text-foreground-light" />
          <h2 class="reveal-title font-h2 max-w-xl">{faq.title}</h2>
        </div>

        <div class="grid gap-3">
          {
            faq.items.map((item: FaqItem, index: number) => (
              <details class="reveal-card group border border-divider-light bg-background-light p-6 open:border-primary" style={`transition-delay: ${index * 55}ms`}>
                <summary class="flex cursor-pointer list-none items-start justify-between gap-6">
                  <span class="font-h5">{item.question}</span>
                  <Icon
                    name="lucide:plus"
                    class="mt-1 size-5 shrink-0 text-primary transition duration-300 group-open:rotate-45"
                    aria-hidden="true"
                  />
                </summary>
                <p class="mt-5 max-w-3xl leading-relaxed text-secondary-foreground-light">
                  {item.answer}
                </p>
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="bg-primary py-18 text-primary-foreground lg:py-28">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
        <div class="flex flex-col gap-6">
          <SubHeading text={cta.eyebrow} class="[&_span:last-child]:border-primary-foreground" />
          <h2 class="reveal-title font-h2 max-w-4xl">
            {cta.title}
          </h2>
        </div>
        <div class="flex flex-col gap-8">
          <p class="max-w-xl text-lg leading-relaxed sm:text-xl">
            {cta.text}
          </p>
          <div class="flex flex-wrap gap-2">
            <Button
              as="a"
              href={cta.primaryCta.href}
              text={cta.primaryCta.text}
              variant="dark"
              iconEnd="lucide:arrow-right"
            />
            <Button
              as="a"
              href={cta.secondaryCta.href}
              text={cta.secondaryCta.text}
              variant="outline"
              class="border-primary-foreground text-primary-foreground hover:bg-primary-foreground hover:text-primary"
              iconEnd="lucide:file-text"
            />
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
