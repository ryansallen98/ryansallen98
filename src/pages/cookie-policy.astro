---
import PolicyDocument from "@components/content/PolicyDocument.astro";
import Layout from "@layouts/BaseLayout.astro";
import policies from "@data/general/policies.yml";

type PolicyPage = {
  key: string;
  eyebrow: string;
  title: string;
  slug: string;
  seo?: Record<string, unknown>;
  summary: string;
  updated: string;
  sections: {
    title: string;
    body: string;
  }[];
};

const pages = policies.pages as PolicyPage[];
const policy = pages.find((page: PolicyPage) => page.key === "cookies");
const related = pages.filter((page: PolicyPage) => page.key !== "cookies");

if (!policy) {
  throw new Error("Missing cookie policy data");
}
---

<Layout title={policy.title} seo={policy.seo}>
  <PolicyDocument policy={policy} related={related} labels={policies.labels} cta={policies.cta} />
</Layout>
