---
import Button from "@components/ui/Button.astro";
import ListItem from "@components/ui/ListItem.astro";
import SubHeading from "@components/ui/SubHeading.astro";
import Layout from "@layouts/BaseLayout.astro";
import quote from "@data/general/quote.yml";
import { Icon } from "astro-icon/components";

type QuoteOption = {
  label: string;
  value: string;
  description?: string;
};

const hero = quote.hero;
const wizard = quote.wizard;
const quoteConfig = JSON.stringify({
  wizard,
  estimates: quote.estimates,
  result: quote.result,
});
const totalSteps = 6;
---

<Layout title={hero.title}>
  <section class="relative overflow-hidden bg-background-dark pt-34 pb-18 text-foreground-dark sm:pt-40 lg:pt-48 lg:pb-24">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute -right-24 top-32 h-80 w-80 rounded-full border border-primary/25"></div>
      <div class="absolute left-8 bottom-12 h-28 w-28 rounded-full border border-divider-dark"></div>
    </div>

    <div class="container relative mx-auto max-w-7xl px-5">
      <div class="grid gap-10 lg:grid-cols-[1fr_0.72fr] lg:items-end">
        <div class="flex flex-col gap-7">
          <SubHeading text={hero.eyebrow} class="fade-in" />
          <h1 class="font-h1 max-w-6xl fade-in delay-200">{hero.title}</h1>
        </div>
        <div class="flex flex-col gap-6 fade-in delay-400">
          <p class="text-lg leading-relaxed text-muted sm:text-xl">{hero.intro}</p>
          <p class="border-l border-primary pl-4 text-sm leading-relaxed text-muted">
            {hero.note}
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-secondary-light py-18 text-foreground-light lg:py-28">
    <div class="container mx-auto max-w-7xl px-5">
      <div
        class="grid gap-6 lg:grid-cols-[minmax(0,0.72fr)_minmax(320px,0.28fr)]"
        x-data={`quoteWizard(${quoteConfig})`}
      >
        <div class="border border-divider-light bg-background-light">
          <div class="border-b border-divider-light p-5 sm:p-8">
            <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
              <div class="flex flex-col gap-4">
                <SubHeading text={wizard.eyebrow} class="text-foreground-light" />
                <h2 class="font-h2">{wizard.title}</h2>
              </div>
              <p class="text-sm uppercase text-secondary-foreground-light">
                {wizard.progressLabel}
                <span x-text="currentStep + 1"></span> / {totalSteps}
              </p>
            </div>
            <div class="mt-6 h-1 bg-divider-light">
              <div
                class="h-full bg-primary transition-all duration-500"
                x-bind:style="`width: ${((currentStep + 1) / 6) * 100}%`"
              ></div>
            </div>
          </div>

          <div class="p-5 sm:p-8">
            <div x-show="currentStep === 0" class="flex flex-col gap-6">
              <div>
                <h3 class="font-h3">{wizard.steps.projectType.title}</h3>
                <p class="mt-2 max-w-2xl text-secondary-foreground-light">
                  {wizard.steps.projectType.help}
                </p>
              </div>
              <div class="grid gap-3">
                {
                  wizard.steps.projectType.options.map((option: QuoteOption) => (
                    <button
                      type="button"
                      class="group border border-divider-light p-5 text-left transition hover:border-primary hover:bg-secondary-light"
                      x-bind:class={`answers.projectType === '${option.value}' ? 'border-primary bg-secondary-light' : ''`}
                      @click={`selectSingle('projectType', '${option.value}')`}
                    >
                      <span class="flex items-start justify-between gap-5">
                        <span>
                          <span class="block font-heading text-2xl uppercase">{option.label}</span>
                          <span class="mt-2 block text-sm leading-relaxed text-secondary-foreground-light">
                            {option.description}
                          </span>
                        </span>
                        <Icon
                          name="lucide:arrow-up-right"
                          class="size-5 text-primary transition group-hover:translate-x-1 group-hover:-translate-y-1"
                          aria-hidden="true"
                        />
                      </span>
                    </button>
                  ))
                }
              </div>
            </div>

            <div x-show="currentStep === 1" class="flex flex-col gap-6">
              <div>
                <h3 class="font-h3">{wizard.steps.stack.title}</h3>
                <p class="mt-2 max-w-2xl text-secondary-foreground-light">
                  {wizard.steps.stack.help}
                </p>
              </div>
              <template x-for="option in getStackOptions()" :key="option.value">
                <button
                  type="button"
                  class="border border-divider-light p-5 text-left transition hover:border-primary hover:bg-secondary-light"
                  x-bind:class="answers.stack === option.value ? 'border-primary bg-secondary-light' : ''"
                  @click="selectSingle('stack', option.value)"
                >
                  <span class="font-heading text-2xl uppercase" x-text="option.label"></span>
                </button>
              </template>
            </div>

            <div x-show="currentStep === 2" class="flex flex-col gap-6">
              <div>
                <h3 class="font-h3">{wizard.steps.scope.title}</h3>
                <p class="mt-2 max-w-2xl text-secondary-foreground-light">
                  {wizard.steps.scope.help}
                </p>
              </div>
              <div class="grid gap-3 md:grid-cols-3">
                {
                  wizard.steps.scope.options.map((option: QuoteOption) => (
                    <button
                      type="button"
                      class="border border-divider-light p-5 text-left transition hover:border-primary hover:bg-secondary-light"
                      x-bind:class={`answers.scope === '${option.value}' ? 'border-primary bg-secondary-light' : ''`}
                      @click={`selectSingle('scope', '${option.value}')`}
                    >
                      <span class="block font-heading text-2xl uppercase">{option.label}</span>
                      <span class="mt-2 block text-sm leading-relaxed text-secondary-foreground-light">
                        {option.description}
                      </span>
                    </button>
                  ))
                }
              </div>
            </div>

            <div x-show="currentStep === 3" class="flex flex-col gap-6">
              <div>
                <h3 class="font-h3">{wizard.steps.extras.title}</h3>
                <p class="mt-2 max-w-2xl text-secondary-foreground-light">
                  {wizard.steps.extras.help}
                </p>
              </div>
              <div class="grid gap-3 sm:grid-cols-2">
                {
                  wizard.steps.extras.options.map((option: QuoteOption) => (
                    <button
                      type="button"
                      class="border border-divider-light p-5 text-left transition hover:border-primary hover:bg-secondary-light"
                      x-bind:class={`answers.extras.includes('${option.value}') ? 'border-primary bg-secondary-light' : ''`}
                      @click={`toggleExtra('${option.value}')`}
                    >
                      <span class="flex items-center gap-3">
                        <span class="size-2 bg-primary"></span>
                        <span class="font-medium uppercase">{option.label}</span>
                      </span>
                    </button>
                  ))
                }
              </div>
            </div>

            <div x-show="currentStep === 4" class="flex flex-col gap-6">
              <div>
                <h3 class="font-h3">{wizard.steps.timeline.title}</h3>
                <p class="mt-2 max-w-2xl text-secondary-foreground-light">
                  {wizard.steps.timeline.help}
                </p>
              </div>
              <div class="grid gap-3 md:grid-cols-3">
                {
                  wizard.steps.timeline.options.map((option: QuoteOption) => (
                    <button
                      type="button"
                      class="border border-divider-light p-5 text-left transition hover:border-primary hover:bg-secondary-light"
                      x-bind:class={`answers.timeline === '${option.value}' ? 'border-primary bg-secondary-light' : ''`}
                      @click={`selectSingle('timeline', '${option.value}')`}
                    >
                      <span class="font-heading text-2xl uppercase">{option.label}</span>
                    </button>
                  ))
                }
              </div>
            </div>

            <div x-show="currentStep === 5" class="flex flex-col gap-6">
              <div>
                <h3 class="font-h3">{wizard.steps.contact.title}</h3>
                <p class="mt-2 max-w-2xl text-secondary-foreground-light">
                  {wizard.steps.contact.help}
                </p>
              </div>

              <form
                name="quote-request"
                method="POST"
                data-netlify="true"
                netlify-honeypot="bot-field"
                class="grid gap-4"
                @submit="handleSubmit()"
              >
                <input type="hidden" name="form-name" value="quote-request" />
                <p class="hidden">
                  <label>Do not fill this out <input name="bot-field" /></label>
                </p>
                <input type="hidden" name="estimate" x-bind:value="getEstimate()" />
                <input type="hidden" name="quote_summary" x-bind:value="getSummary()" />

                <div class="grid gap-4 sm:grid-cols-2">
                  <label class="flex flex-col gap-2 text-sm uppercase">
                    {wizard.steps.contact.fields.name}
                    <input
                      class="border border-divider-light bg-background-light px-4 py-3 text-base normal-case"
                      name="name"
                      required
                      x-model="contact.name"
                    />
                  </label>
                  <label class="flex flex-col gap-2 text-sm uppercase">
                    {wizard.steps.contact.fields.email}
                    <input
                      class="border border-divider-light bg-background-light px-4 py-3 text-base normal-case"
                      type="email"
                      name="email"
                      required
                      x-model="contact.email"
                    />
                  </label>
                </div>

                <div class="grid gap-4 sm:grid-cols-2">
                  <label class="flex flex-col gap-2 text-sm uppercase">
                    {wizard.steps.contact.fields.phone}
                    <input
                      class="border border-divider-light bg-background-light px-4 py-3 text-base normal-case"
                      name="phone"
                      x-model="contact.phone"
                    />
                  </label>
                  <label class="flex flex-col gap-2 text-sm uppercase">
                    {wizard.steps.contact.fields.contactMethod}
                    <select
                      class="border border-divider-light bg-background-light px-4 py-3 text-base normal-case"
                      name="preferred_contact_method"
                      x-model="contact.contactMethod"
                    >
                      {
                        wizard.steps.contact.contactMethods.map((method: string) => (
                          <option value={method}>{method}</option>
                        ))
                      }
                    </select>
                  </label>
                </div>

                <label class="flex flex-col gap-2 text-sm uppercase">
                  {wizard.steps.contact.fields.message}
                  <textarea
                    class="min-h-36 border border-divider-light bg-background-light px-4 py-3 text-base normal-case"
                    name="message"
                    required
                    x-model="contact.message"
                  ></textarea>
                </label>

                <Button
                  text={wizard.submitLabel}
                  variant="primary"
                  iconEnd="lucide:send"
                  class="w-fit"
                />

                <p
                  class="text-sm text-secondary-foreground-light"
                  x-show="isSubmitted"
                  x-text="config.wizard.successText"
                ></p>
              </form>
            </div>

            <div class="mt-8 flex flex-wrap gap-2 border-t border-divider-light pt-6">
              <button
                type="button"
                class="px-6 py-4 text-sm uppercase text-secondary-foreground-light transition hover:text-foreground-light"
                x-show="currentStep > 0"
                @click="back()"
              >
                {wizard.backLabel}
              </button>
              <button
                type="button"
                class="bg-primary px-8 py-4 text-sm font-medium uppercase text-primary-foreground transition disabled:cursor-not-allowed disabled:opacity-40"
                x-show="currentStep < 5"
                x-bind:disabled="!canContinue()"
                @click="next()"
              >
                {wizard.nextLabel}
              </button>
            </div>
          </div>
        </div>

        <aside class="h-fit border border-divider-light bg-background-light p-5 sm:p-8 lg:sticky lg:top-28">
          <div class="flex flex-col gap-6">
            <SubHeading text={wizard.summaryLabel} class="text-foreground-light" />
            <div class="border-b border-divider-light pb-5">
              <p class="text-sm uppercase text-secondary-foreground-light" x-text="needsDiscovery() ? config.wizard.discoveryLabel : config.wizard.estimateLabel"></p>
              <p class="font-h3 mt-2 text-primary" x-text="getEstimate()"></p>
              <p class="mt-3 text-sm leading-relaxed text-secondary-foreground-light" x-text="getResultText()"></p>
            </div>

            <ul class="flex flex-col gap-3 text-sm">
              <ListItem as="li">
                <span x-text="getAnswerLabel('projectType', answers.projectType)"></span>
              </ListItem>
              <ListItem as="li">
                <span x-text="getAnswerLabel('stack', answers.stack)"></span>
              </ListItem>
              <ListItem as="li">
                <span x-text="getAnswerLabel('scope', answers.scope)"></span>
              </ListItem>
              <ListItem as="li">
                <span x-text="getExtrasSummary()"></span>
              </ListItem>
              <ListItem as="li">
                <span x-text="getAnswerLabel('timeline', answers.timeline)"></span>
              </ListItem>
            </ul>

            <p class="border-t border-divider-light pt-5 text-sm leading-relaxed text-secondary-foreground-light">
              {wizard.hourlyNote}
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>
