---
import ResumeSubTitle from "./ResumeSubTitle.astro";

const { resume } = Astro.props;
---

<div class="flex flex-row">
  <div class="w-2/3">
    <div class="flex flex-col gap-2 px-16 pt-16 pb-10 bg-background-light relative z-20 -mb-0.5">
      <h1 class="text-5xl font-semibold uppercase tracking-widest">
        {resume.name}
      </h1>
      <div
        class="flex flex-row items-center w-full gap-2 text-secondary-foreground-light"
      >
        <h2 class="text-lg tracking-wide">{resume.headline}</h2>
        <hr class="min-w-10 border border-secondary-foreground-light" />
      </div>
    </div>
    <div class="bg-primary text-primary-foreground pl-16 flex flex-col">
      <div class="bg-background-light flex flex-row">
        <div
          class="bg-primary w-fit h-13 pr-15 pt-4 -mb-px"
          style="clip-path: polygon(0 0, calc(100% - calc(var(--spacing) * 10)) 0, 100% 100%, 0% 100%);"
        >
          <ResumeSubTitle title="Profile" />
        </div>
        <div
          class="max-w-20 h-10.5 w-20 self-start overflow-hidden"
          style="margin-left: calc((var(--spacing) * -10) + (var(--spacing) * 3));"
        >
          <div
            class="bg-muted h-13 w-full"
            style="clip-path: polygon(0 0, calc(100% - calc(var(--spacing) * 10)) 0, 100% 100%, calc(var(--spacing) * 10) 100%);"
          >
          </div>
        </div>
      </div>
      <div class="h-24 flex items-center py-2 pr-5">
        <p class="leading-relaxed text-xs">
          {resume.profile}
        </p>
      </div>
    </div>
  </div>
  <div
    class="w-1/3 bg-secondary-dark text-secondary-foreground-dark bg-cover bg-center flex items-end"
    style={`background-image: url(${resume.photo.src});`}
    role="img"
    aria-label={resume.photo.alt}
  >
    <div class="w-full h-24 bg-primary/50"></div>
  </div>
</div>
