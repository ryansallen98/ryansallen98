---
import ResumeSubTitle from "./ResumeSubTitle.astro";

type ContactItem = {
  label: string;
  value: string;
  href?: string;
};

type EducationItem = {
  school: string;
  qualification: string;
  dates?: string;
};

type Resume = {
  contact: ContactItem[];
  focus: string;
  skillPills: string[];
  education: EducationItem[];
};

const { resume } = Astro.props as { resume: Resume };
---

<aside class="w-1/3 bg-secondary-dark text-secondary-foreground-dark px-8 py-7 flex flex-col gap-5">
  <section>
    <ResumeSubTitle title="Contact" mode="dark" />
    <div class="mt-2 flex flex-col gap-0.5">
      {resume.contact.map((item) => (
        <div class="border-b border-divider-dark pb-1">
          <p class="text-[8px] uppercase tracking-widest text-foreground-dark/45 leading-tight">
            {item.label}
          </p>
          {item.href ? (
            <a
              href={item.href}
              class="text-[12px] leading-tight text-foreground-dark wrap-break-word hover:text-primary"
            >
              {item.value}
            </a>
          ) : (
            <p class="text-[12px] leading-tight text-foreground-dark wrap-break-word">
              {item.value}
            </p>
          )}
        </div>
      ))}
    </div>
  </section>

  <section>
    <ResumeSubTitle title="Focus" mode="dark" />
    <p class="mt-3 text-[11px] leading-snug text-foreground-dark/80">
      {resume.focus}
    </p>
  </section>

  <section>
    <ResumeSubTitle title="Skills" mode="dark" />
    <div class="mt-3 flex flex-wrap gap-1.5">
      {resume.skillPills.map((skill) => (
        <span class="border border-divider-dark bg-foreground-dark/5 px-2 py-1 text-[10px] leading-none text-foreground-dark/90">
          {skill}
        </span>
      ))}
    </div>
  </section>

  <section>
    <ResumeSubTitle title="Education" mode="dark" />
    <div class="mt-3">
      {resume.education.map((item) => (
        <div class="flex flex-col gap-1">
          <h3 class="text-[12px] font-semibold uppercase tracking-wide text-foreground-dark leading-snug">
            {item.school}
          </h3>
          <p class="text-[11px] leading-snug text-foreground-dark/75">
            {item.qualification}
          </p>
          {item.dates && (
            <p class="text-[9px] uppercase tracking-widest text-foreground-dark/50 leading-snug">
              {item.dates}
            </p>
          )}
        </div>
      ))}
    </div>
  </section>

</aside>
