---
import Button from "@components/ui/Button.astro";
import ListItem from "@components/ui/ListItem.astro";
import SubHeading from "@components/ui/SubHeading.astro";
import Layout from "@layouts/BaseLayout.astro";
import availability from "@data/general/availability.yml";

type Cta = {
  text: string;
  href: string;
};

type StatusItem = {
  label: string;
  value: string;
};

const hero = availability.hero as {
  eyebrow: string;
  title: string;
  intro: string;
  primaryCta: Cta;
  secondaryCta: Cta;
};
const status = availability.status as {
  eyebrow: string;
  title: string;
  text: string;
  items: StatusItem[];
};
const fits = availability.fits as {
  eyebrow: string;
  title: string;
  items: string[];
};
const cta = availability.cta as {
  eyebrow: string;
  title: string;
  text: string;
  primaryCta: Cta;
  secondaryCta: Cta;
};
---

<Layout title={hero.title}>
  <section class="bg-background-dark pt-28 pb-16 text-foreground-dark sm:pt-32 lg:pt-36 lg:pb-24">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="grid gap-8 lg:grid-cols-[1fr_0.75fr] lg:items-end">
        <div class="flex flex-col gap-7">
          <SubHeading text={hero.eyebrow} />
          <h1 class="reveal-title font-hero max-w-5xl">{hero.title}</h1>
        </div>
        <div class="flex flex-col gap-7">
          <p class="max-w-xl text-lg leading-relaxed text-muted">{hero.intro}</p>
          <div class="flex flex-wrap gap-2">
            <Button as="a" href={hero.primaryCta.href} text={hero.primaryCta.text} variant="primary" iconEnd="lucide:arrow-right" />
            <Button as="a" href={hero.secondaryCta.href} text={hero.secondaryCta.text} variant="outline" iconEnd="lucide:arrow-right" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background-light py-18 text-foreground-light lg:py-28">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
        <div class="flex flex-col gap-6">
          <SubHeading text={status.eyebrow} class="text-foreground-light" />
          <h2 class="reveal-title font-h2 max-w-xl">{status.title}</h2>
          <p class="max-w-xl leading-relaxed text-secondary-foreground-light">{status.text}</p>
        </div>
        <div class="grid gap-4">
          {
            status.items.map((item: StatusItem, index: number) => (
              <article class="reveal-card border border-divider-light bg-secondary-light p-6" style={`transition-delay: ${index * 80}ms`}>
                <p class="text-sm uppercase text-secondary-foreground-light">{item.label}</p>
                <h3 class="font-h4 mt-2">{item.value}</h3>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="bg-background-dark py-18 text-foreground-dark lg:py-24">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
        <div class="flex flex-col gap-6">
          <SubHeading text={fits.eyebrow} />
          <h2 class="reveal-title font-h2 max-w-xl">{fits.title}</h2>
        </div>
        <ul class="grid gap-4 sm:grid-cols-2">
          {fits.items.map((item: string) => <ListItem>{item}</ListItem>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-primary py-18 text-primary-foreground lg:py-24">
    <div class="container mx-auto max-w-7xl px-5">
      <div class="grid gap-8 lg:grid-cols-[1fr_0.8fr] lg:items-end">
        <div class="flex flex-col gap-5">
          <SubHeading text={cta.eyebrow} class="[&_span:last-child]:border-primary-foreground" />
          <h2 class="font-h2 max-w-3xl">{cta.title}</h2>
        </div>
        <div class="flex flex-col gap-7">
          <p class="max-w-xl text-lg leading-relaxed">{cta.text}</p>
          <div class="flex flex-wrap gap-2">
            <Button as="a" href={cta.primaryCta.href} text={cta.primaryCta.text} variant="dark" iconEnd="lucide:arrow-right" />
            <Button as="a" href={cta.secondaryCta.href} text={cta.secondaryCta.text} variant="outline" class="border-primary-foreground text-primary-foreground hover:bg-primary-foreground hover:text-primary" iconEnd="lucide:arrow-right" />
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
