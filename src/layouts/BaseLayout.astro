---
import "@styles/global.css";

import ShellLayout from "@layouts/ShellLayout.astro";
import Header from "@components/layout/Header.astro";
import Footer from "@components/layout/Footer.astro";
import ComingSoon from "@components/content/ComingSoon.astro";

const isComingSoon = import.meta.env.COMING_SOON === "true";

const { chrome = true, preloadImage } = Astro.props;
---

<ShellLayout {...Astro.props}>
  <Fragment slot="head">
    <link
      rel="preload"
      href="/fonts/Anton-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    {
      preloadImage && (
        <link
          rel="preload"
          href={preloadImage}
          as="image"
          fetchpriority="high"
        />
      )
    }
    <slot name="head" />
  </Fragment>
  {isComingSoon ? 
    <ComingSoon />
    :
    <>
      {chrome && <Header />}
      <main>
        <slot />
      </main>
      {chrome && <Footer />}
      <script src="@scripts/global"></script>
    </>
  }
</ShellLayout>
