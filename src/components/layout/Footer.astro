---
import SubHeading from "@components/ui/SubHeading.astro";
import NavLink from "@components/navigation/NavLink.astro";
import layout from "@data/general/layout.yml";
import meta from "@data/general/meta.yml";
import Socials from "@components/content/Socials.astro";
import { Icon } from "astro-icon/components";
import Button from "@components/ui/Button.astro";
import Name from "@components/branding/Name.astro";

const legalMatch = meta.legalName === meta.siteName;
const copyrightCompany = legalMatch
  ? meta.legalName
  : `${meta.legalName} trading as ${meta.siteName}`;

type FooterLink = {
  text: string;
  href: string;
};

type FooterMenu = {
  heading: string;
  links: FooterLink[];
};

type FooterLocation = {
  country: string;
  locality: string;
};

type FooterContact = {
  label: string;
  href: string;
  icon: string;
};

const footer = layout.footer as {
  cta: {
    eyebrow: string;
    text: string;
    button: FooterLink;
  };
  menus: FooterMenu[];
  locations: {
    heading: string;
    items: FooterLocation[];
  };
  contact: {
    heading: string;
    items: FooterContact[];
  };
  socialsHeading: string;
  copyrightSuffix: string;
};
---

<footer class="bg-background-dark text-foreground-dark" transition:persist>
  <div class="container mx-auto max-w-7xl px-5 py-10 lg:py-6">
    <div class="flex flex-col justify-between items-stretch gap-12 lg:flex-row lg:gap-8">
      <!-- Footer Right -->
      <div
        class="order-first flex w-full flex-col justify-between gap-8 lg:order-last lg:w-[45%] lg:flex-1"
      >
        <div class="flex max-w-2xl flex-col gap-6 lg:gap-8">
          <SubHeading text={footer.cta.eyebrow} as="h3" />
          <p class="text-lg leading-relaxed text-muted sm:text-xl">
            {footer.cta.text}
          </p>
          <Button
            as="a"
            href={footer.cta.button.href}
            text={footer.cta.button.text}
            variant="primary"
            iconEnd="lucide:arrow-right"
          />
        </div>
        <Name class="h-fit w-full max-w-2xl lg:max-w-none" />
      </div>

      <!-- Footer Left -->
      <div class="flex w-full flex-col justify-between gap-10 lg:w-[55%] lg:gap-15">
        <!-- Footer Menu -->
        <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-3 lg:gap-4 lg:gap-y-16">
          {
            footer.menus.map((menu: FooterMenu) => (
              <div class="flex flex-col gap-5 lg:gap-8">
                <SubHeading text={menu.heading} as="h3" />
                <ul class="flex flex-col gap-2 w-fit items-start">
                  {menu.links.map((link: FooterLink) => (
                    <NavLink href={link.href} text={link.text} />
                  ))}
                </ul>
              </div>
            ))
          }

          <div class="flex flex-col gap-5 lg:gap-8">
            <SubHeading text={footer.locations.heading} as="h3" />
            <ul class="flex flex-col gap-4 lg:gap-6">
              {
                footer.locations.items.map((location: FooterLocation) => (
                  <li class="flex flex-row gap-2">
                    <Icon
                      name="mdi:map-marker"
                      class="inline-block w-5 h-5 mt-0.5 mr-0.5 text-primary"
                      aria-hidden="true"
                    />
                    <div class="text-muted">
                      <p>{location.country}</p>
                      <p>{location.locality}</p>
                    </div>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="flex flex-col gap-5 lg:gap-8">
            <SubHeading text={footer.contact.heading} as="h3" />
            <ul class="flex flex-col gap-3 lg:gap-4">
              {
                footer.contact.items.map((item: FooterContact) => (
                  <li>
                    <a
                      href={item.href}
                      target={item.href.startsWith("http") ? "_blank" : undefined}
                      rel={item.href.startsWith("http") ? "noopener noreferrer" : undefined}
                      class="flex flex-row gap-2 transition-all duration-300 text-muted hover:text-foreground-dark focus-visible:text-foreground-dark"
                    >
                      <Icon
                        name={item.icon}
                        class="inline-block w-5 h-5 mt-0.5 mr-0.5 text-primary"
                        aria-hidden="true"
                      />
                      <span class="inline-block">{item.label}</span>
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="flex flex-col gap-5 lg:gap-8">
            <SubHeading text={footer.socialsHeading} as="h3" />

            <Socials />
          </div>
        </div>

        <!-- Footer Copyright & Disclaimer -->
        <div
          class="flex flex-col gap-2 border-t border-b border-divider-dark py-5 text-xs uppercase leading-relaxed text-muted sm:flex-row sm:items-center sm:justify-between lg:py-6"
        >
          <p>
            &copy; {new Date().getFullYear()}
            {copyrightCompany}. {footer.copyrightSuffix}
          </p>
        </div>
      </div>
    </div>
  </div>
</footer>
