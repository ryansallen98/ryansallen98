---
import NavLink from "./NavLink.astro";
import layout from "@data/general/layout.yml";

type NavItem = {
  text: string;
  href: string;
  variant?: "default" | "primary";
};

const links = (Astro.props.links ?? layout.header.links) as NavItem[];
---

<nav
  class="flex flex-row items-start justify-center"
  aria-label="Main navigation"
>
  <ul class="flex flex-row items-center justify-center gap-8 pr-4" data-menu>
    {links.map((link: NavItem) => <NavLink text={link.text} href={link.href} variant={link.variant} />)}
  </ul>
</nav>
